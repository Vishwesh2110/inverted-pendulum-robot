<?xml version="1.0"?>
<sdf version="1.6">
  <world name="default">

    <!-- Ground -->
    <include>
      <uri>model://ground_plane</uri>
    </include>

    <!-- Light -->
    <include>
      <uri>model://sun</uri>
    </include>

    <!-- Physics -->
    <physics type="ode">
      <real_time_update_rate>50</real_time_update_rate>
    </physics>

  </world>
</sdf>